generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MASTER
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  email         String         @unique
  password_hash String
  role          Role           @default(USER)
  documents     Document[]
  
  // New relations
  modules       TrainingModule[] @relation("MasterModules")
  submissions   QuizSubmission[]
  threads       ForumThread[]
  replies       ForumReply[]
  accessLogs    ModuleAccessLog[]
  videoProgress ModuleVideoProgress[]
  downloads     ModuleDocumentDownload[]
  placements    WorldModulePlacement[] @relation("MasterPlacements")
  auditLogs     AuditLog[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Document {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  name      String
  type      String   // e.g., 'application/pdf'
  data      Bytes    // Binary storage
  
  // New relation
  moduleDocs ModuleDocument[]

  createdAt DateTime @default(now())
}

// New Enums
enum ModuleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PlacementStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum LogSource {
  DASHBOARD
  MULTIPLAYER_WORLD
}

// New Models

model TrainingModule {
  id             Int          @id @default(autoincrement())
  ownerMasterId  Int
  master         User         @relation("MasterModules", fields: [ownerMasterId], references: [id])
  title          String
  description    String?
  coverImage     String?
  status         ModuleStatus @default(DRAFT)
  
  videos         ModuleVideo[]
  documents      ModuleDocument[]
  quizzes        Quiz[]
  submissions    QuizSubmission[]
  threads        ForumThread[]
  accessLogs     ModuleAccessLog[]
  placements     WorldModulePlacement[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ModuleVideo {
  id         Int          @id @default(autoincrement())
  moduleId   Int
  module     TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title      String
  url        String
  order      Int
  progress   ModuleVideoProgress[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model ModuleDocument {
  id         Int          @id @default(autoincrement())
  moduleId   Int
  module     TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  documentId Int
  document   Document     @relation(fields: [documentId], references: [id])
  title      String
  order      Int
  downloads  ModuleDocumentDownload[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Quiz {
  id         Int          @id @default(autoincrement())
  moduleId   Int
  module     TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title      String
  order      Int
  questions  QuizQuestion[]
  submissions QuizSubmission[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model QuizQuestion {
  id         Int          @id @default(autoincrement())
  quizId     Int
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text       String
  order      Int
  options    QuizOption[]
  answers    QuizAnswer[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model QuizOption {
  id         Int          @id @default(autoincrement())
  questionId Int
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean
  answers    QuizAnswer[]
}

model QuizSubmission {
  id            Int          @id @default(autoincrement())
  moduleId      Int
  module        TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizId        Int?
  quiz          Quiz?        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId        Int
  user          User         @relation(fields: [userId], references: [id])
  score         Float
  attemptNumber Int
  answers       QuizAnswer[]
  createdAt     DateTime     @default(now())
}

model QuizAnswer {
  id           Int          @id @default(autoincrement())
  submissionId Int
  submission   QuizSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   Int
  question     QuizQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionId     Int
  option       QuizOption     @relation(fields: [optionId], references: [id], onDelete: Cascade)
}

model ForumThread {
  id        Int          @id @default(autoincrement())
  moduleId  Int
  module    TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  title     String
  content   String
  replies   ForumReply[]
  createdAt DateTime     @default(now())
}

model ForumReply {
  id        Int          @id @default(autoincrement())
  threadId  Int
  thread    ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime     @default(now())
}

model ModuleAccessLog {
  id          Int            @id @default(autoincrement())
  moduleId    Int
  module      TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userId      Int
  user        User           @relation(fields: [userId], references: [id])
  placementId Int?           // Optional: link to a specific placement
  sceneId     String?        // Optional: link to a specific scene/world
  source      LogSource
  timestamp   DateTime       @default(now())
}

model ModuleVideoProgress {
  id        Int          @id @default(autoincrement())
  videoId   Int
  video     ModuleVideo  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  progress  Float        // 0 to 100
  completed Boolean      @default(false)
  updatedAt DateTime     @updatedAt

  @@unique([videoId, userId])
}

model ModuleDocumentDownload {
  id          Int            @id @default(autoincrement())
  moduleDocId Int
  moduleDoc   ModuleDocument @relation(fields: [moduleDocId], references: [id], onDelete: Cascade)
  userId      Int
  user        User           @relation(fields: [userId], references: [id])
  timestamp   DateTime       @default(now())
}

model WorldModulePlacement {
  id            Int             @id @default(autoincrement())
  ownerMasterId Int
  master        User            @relation("MasterPlacements", fields: [ownerMasterId], references: [id])
  moduleId      Int?
  module        TrainingModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  sceneId       String
  objectType    String
  label         String?
  positionX     Float
  positionY     Float
  positionZ     Float
  rotationX     Float
  rotationY     Float
  rotationZ     Float
  scaleX        Float
  scaleY        Float
  scaleZ        Float
  status        PlacementStatus @default(ACTIVE)
  modelData      Bytes?          // Binary GLB file
  idleAnim       String?         // Idle animation name
  interactedAnim String?         // Interaction animation name
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   Int?
  details    Json?
  createdAt  DateTime @default(now())
}
